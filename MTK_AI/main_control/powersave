#!/system/bin/sh

PID_FILE="/data/adb/modules/MTK_AI/touch.pid"
echo $$ > "$PID_FILE"
renice -n -20 -p $$
if [ -f /proc/$$/oom_score_adj ]; then
    echo -1000 > /proc/$$/oom_score_adj
fi
echo $$ > /dev/cpuset/top-app/tasks 2>/dev/null

CPU_SYS="/sys/devices/system/cpu" 

TOUCH_DEV=$(getevent -p | grep -B 15 "0035" | grep "/dev/input/" | tail -n 1 | awk '{print $NF}')
MOD_DIR="/data/adb/modules/MTK_AI"
EXTERNAL_CFG="/sdcard/MTK_AI_Engine"
NOTIFY_ENABLED_FILE="$EXTERNAL_CFG/enable_notifications"
TIMEOUT=5
if [ -f "/sdcard/MTK_AI_Engine/touch_timeout.txt" ]; then
    CUSTOM_TIMEOUT=$(cat "/sdcard/MTK_AI_Engine/touch_timeout.txt" | tr -d '\r\n ')
    if [ "$CUSTOM_TIMEOUT" -ge 3 ] 2>/dev/null && [ "$CUSTOM_TIMEOUT" -le 10 ] 2>/dev/null; then
        TIMEOUT=$CUSTOM_TIMEOUT
    fi
fi

# --- Function to detect foreground app ---
get_foreground_app() {
    local pkg=""
    pkg=$(timeout 2s dumpsys window windows 2>/dev/null | grep -E 'mCurrentFocus|mFocusedApp' | head -n 1 | grep -oE '[a-zA-Z][a-zA-Z0-9_]*\.[a-zA-Z0-9_.]+/' | head -1 | tr -d '/')
    if [ -z "$pkg" ]; then
        pkg=$(timeout 2s dumpsys activity activities 2>/dev/null | grep "mResumedActivity" | head -n 1 | grep -oE '[a-zA-Z][a-zA-Z0-9_]*\.[a-zA-Z0-9_.]+/' | head -1 | tr -d '/')
    fi
    if [ -z "$pkg" ]; then
        pkg=$(timeout 2s dumpsys activity top 2>/dev/null | grep "ACTIVITY" | tail -n 1 | awk '{print $2}' | cut -d'/' -f1)
    fi
    echo "${pkg:-unknown}"
}

touch_active() {
    for p in $CPU_SYS/cpufreq/policy*; do
        [ -d "$p" ] || continue
        [ -w "$p/schedutil/rate_limit_us" ] && echo 100 > "$p/schedutil/rate_limit_us"
    done

    TOUCH_ACTIVE_PERCENT=100
    if [ -f "/sdcard/MTK_AI_Engine/manual_touch_active_freq.txt" ]; then
        TOUCH_ACTIVE_PERCENT=$(cat "/sdcard/MTK_AI_Engine/manual_touch_active_freq.txt" | tr -d '\r\n ')
        if [ "$TOUCH_ACTIVE_PERCENT" -lt 50 ] 2>/dev/null; then TOUCH_ACTIVE_PERCENT=50; fi
        if [ "$TOUCH_ACTIVE_PERCENT" -gt 100 ] 2>/dev/null; then TOUCH_ACTIVE_PERCENT=100; fi
    fi

    REFRESH_FILE="/sdcard/MTK_AI_Engine/manual_refresh_lock.txt"
    if [ -f "$REFRESH_FILE" ]; then
        MODE_ID=$(tr -d '\r\n\t ' < "$REFRESH_FILE")
        if [ -n "$MODE_ID" ] && [ "$MODE_ID" -eq "$MODE_ID" ] 2>/dev/null; then
            service call SurfaceFlinger 1035 i32 "$MODE_ID" >/dev/null 2>&1
        fi
    fi

    for cpu in $CPU_SYS/cpu[0-9]*; do
        MAX_FREQ=$(cat "$cpu/cpufreq/cpuinfo_max_freq")
        MIN_FREQ=$(cat "$cpu/cpufreq/cpuinfo_min_freq")
        TARGET_MAX=$((MAX_FREQ * TOUCH_ACTIVE_PERCENT / 100))
        chmod 644 "$cpu/cpufreq/scaling_min_freq"
        chmod 644 "$cpu/cpufreq/scaling_max_freq"
        echo "$MIN_FREQ" > "$cpu/cpufreq/scaling_min_freq"
        echo "$TARGET_MAX" > "$cpu/cpufreq/scaling_max_freq"
    done
    pkill -f mtk_ai_engine
    nohup sh "/data/adb/modules/MTK_AI/MTK_AI/AI_MODE/global_mode/ram_cleaner" &
}

touch_inactive() {
    echo 32 > /proc/gpufreqv2/fix_target_opp_index
    su -c "service call SurfaceFlinger 1035 i32 2" 2>/dev/null

    INACTIVE_PERCENT=25
    if [ -f "/sdcard/MTK_AI_Engine/manual_inactive_freq.txt" ]; then
        INACTIVE_PERCENT=$(cat "/sdcard/MTK_AI_Engine/manual_inactive_freq.txt" | tr -d '\r\n ')
        if [ "$INACTIVE_PERCENT" -lt 25 ] 2>/dev/null; then
            INACTIVE_PERCENT=25
        elif [ "$INACTIVE_PERCENT" -gt 50 ] 2>/dev/null; then
            INACTIVE_PERCENT=50
        fi
    fi

    for policy in $CPU_SYS/cpufreq/policy*; do
        [ -d "$policy" ] || continue
        if [ -f "$policy/cpuinfo_max_freq" ]; then
            max_val=$(cat "$policy/cpuinfo_max_freq")
            target_val=$(( max_val * INACTIVE_PERCENT / 100 ))
            chmod 644 "$policy/scaling_max_freq" 2>/dev/null
            echo "$target_val" > "$policy/scaling_max_freq"
        fi
    done
    sync
}

notify_status() {
    [ ! -f "$NOTIFY_ENABLED_FILE" ] && return 0
    
    # --- Battery Temp ---
    RAW_TEMP=$(cat /sys/class/power_supply/battery/temp)
    B_TEMP="$((RAW_TEMP / 10)).$((RAW_TEMP % 10))°C"
    
    # --- RAM Consumption Calculation ---
    # Read total and available memory (in kB) from /proc/meminfo
    local mem_total=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
    local mem_available=$(awk '/MemAvailable/ {print $2}' /proc/meminfo)
    
    # Fallback for older Android kernels that don't report MemAvailable
    if [ -z "$mem_available" ]; then
        local mem_free=$(awk '/MemFree/ {print $2}' /proc/meminfo)
        local buffers=$(awk '/Buffers/ {print $2}' /proc/meminfo)
        local cached=$(awk '/^Cached/ {print $2}' /proc/meminfo)
        mem_available=$((mem_free + buffers + cached))
    fi
    
    # Calculate the used RAM percentage
    local ram_percent=0
    if [ "$mem_total" -gt 0 ] 2>/dev/null; then
        ram_percent=$(( (mem_total - mem_available) * 100 / mem_total ))
    fi

    # --- App Info ---
    local status_msg="$1"
    local app_name="$2"
    local app_info=""
    if [ -n "$app_name" ] && [ "$app_name" != "unknown" ]; then
        app_info=" | App: $app_name"
    fi
    
    # --- Post Notification ---
    # Added " | RAM: ${ram_percent}%" into the notification text
    su -lp 2000 -c "cmd notification post -I /data/adb/modules/MTK_AI/icon.png -S bigtext -t 'Powersave Mode' tag 'Status : $status_msg | Temp: $B_TEMP | RAM: ${ram_percent}%$app_info'" >/dev/null 2>&1
}

# Initial State
LAST_ACTIVITY=$(date +%s)
STATE="PERF"
LAST_APP=""
LAST_APP_CHECK=$LAST_ACTIVITY

while true; do
    if timeout 1s getevent -c 1 "$TOUCH_DEV" > /dev/null 2>&1; then
        NOW=$(date +%s)
        LAST_ACTIVITY=$NOW
        
        # State transition from SAVE to PERF
        if [ "$STATE" = "SAVE" ]; then
            STATE="PERF"
            touch_active
            
            CURRENT_APP=$(get_foreground_app)
            notify_status "🍁" "$CURRENT_APP"
            LAST_APP="$CURRENT_APP"
            LAST_APP_CHECK=$NOW
            
            # --- GAME DETECTION & ENGINE LAUNCH ---
            if [ -f "/sdcard/MTK_AI_Engine/game_list.txt" ] && [ "$CURRENT_APP" != "unknown" ]; then
                # tr -d '\r' ensures it works even if the text file has Windows line endings
                if tr -d '\r' < "/sdcard/MTK_AI_Engine/game_list.txt" | grep -qx "$CURRENT_APP"; then
                    # Check if the engine is already running to prevent duplicate instances
                    if ! pgrep -f "/data/adb/modules/MTK_AI/main_control/mtk_ai_engine.sh" > /dev/null 2>&1; then
                        echo "1" > /sdcard/MTK_AI_Engine/automode
                        nohup /data/adb/modules/MTK_AI/main_control/mtk_ai_engine.sh >/dev/null 2>&1 &
                    fi
                fi
            fi
        else
            # --- PERIODIC APP CHECK (While already in PERF state) ---
            # Checks every 3 seconds to see if you switched to a game while actively using the phone
            if [ $((NOW - LAST_APP_CHECK)) -ge 3 ]; then
                LAST_APP_CHECK=$NOW
                CURRENT_APP=$(get_foreground_app)
                
                if [ "$CURRENT_APP" != "$LAST_APP" ] && [ "$CURRENT_APP" != "unknown" ]; then
                    LAST_APP="$CURRENT_APP"
                    
                    if [ -f "/sdcard/MTK_AI_Engine/game_list.txt" ]; then
                        if tr -d '\r' < "/sdcard/MTK_AI_Engine/game_list.txt" | grep -qx "$CURRENT_APP"; then
                            if ! pgrep -f "/data/adb/modules/MTK_AI/main_control/mtk_ai_engine.sh" > /dev/null 2>&1; then
                                echo "1" > /sdcard/MTK_AI_Engine/automode
                                nohup /data/adb/modules/MTK_AI/main_control/mtk_ai_engine.sh >/dev/null 2>&1 &
                            fi
                        fi
                    fi
                fi
            fi
        fi
    else
        NOW=$(date +%s)
        ELAPSED=$((NOW - LAST_ACTIVITY))

        if [ "$ELAPSED" -ge "$TIMEOUT" ] && [ "$STATE" = "PERF" ]; then
            if [ -f "$EXTERNAL_CFG/enable_limiter" ]; then
                STATE="SAVE"
                touch_inactive
                # Use LAST_APP here to show the app that was active before going idle
                notify_status "🍀" "$LAST_APP" 
            fi
        fi
    fi

    CUR_TIME=$(date +%s)
    DIFF=$((CUR_TIME - LAST_ACTIVITY))
    printf "\r[Mode: %s] [Idle: %ds]    " "$STATE" "$DIFF"
done
