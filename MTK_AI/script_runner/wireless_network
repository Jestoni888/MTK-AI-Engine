#!/system/bin/sh

MONITOR_FILE="/sys/class/net/wlan0/operstate"

random_device() {
# Generate random device name (format: android-XXXXX)
RANDOM_NAME="$(tr -dc 'a-z0-9' < /dev/urandom | head -c 5)"

# Set global device name (visible in settings)
settings put global device_name "$RANDOM_NAME"

# Set hostname for network requests (DHCP/mDNS)
setprop net.hostname "$RANDOM_NAME"

# Optional: Set persistent hostname in build.prop (requires remount)
# Uncomment if you want to make it persistent across reboots
# mount -o remount,rw /system
# sed -i '/net\.hostname=/d' /system/build.prop
# echo "net.hostname=$RANDOM_NAME" >> /system/build.prop
# mount -o remount,ro /system

# Log the change
log -t DeviceNameRandomizer "Device name changed to: $RANDOM_NAME"

# Apply changes to active connections
if [ -x /system/bin/ndc ]; then
    /system/bin/ndc interface setcfg wlan0 "$RANDOM_NAME"
fi

NEW_MAC="02:$(tr -dc '0-9a-f' < /dev/urandom | head -c 2):$(tr -dc '0-9a-f' < /dev/urandom | head -c 2):$(tr -dc '0-9a-f' < /dev/urandom | head -c 2):$(tr -dc '0-9a-f' < /dev/urandom | head -c 2):$(tr -dc '0-9a-f' < /dev/urandom | head -c 2)"

ip link set dev wlan0 address "$NEW_MAC"

# Verify changes
echo "Device name successfully randomized to: $RANDOM_NAME"
echo "New MAC: $NEW_MAC"
}

# Function to check state and launch the correct script
apply_mode() {
    # Read the current state of the monitor file
    STATE=$(cat "$MONITOR_FILE" 2>/dev/null)
    
    if [ "$STATE" = "down" ]; then
        random_device
    fi
}
apply_mode