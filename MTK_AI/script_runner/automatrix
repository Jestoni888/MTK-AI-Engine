#!/system/bin/sh

### === SINGLE INSTANCE LOCK ===
LOCK_DIR="/data/adb/modules/MTK_AI/.guard"
mkdir -p "$LOCK_DIR"
LOCK_FILE="$LOCK_DIR/global_runner.pid"

# Helper: safe logging (works on all Android versions)
log_msg() { log -t MTK_AI "$@" 2>/dev/null || echo "[MTK_AI] $*"; }

# 1️⃣ Global pgrep check FIRST
if pgrep -f "automatrix" | grep -v "^$$" > /dev/null 2>&1; then
    exit 0
else
    rm -rf "$LOCK_DIR"
fi

# 2️⃣ If PID file exists and process is alive → exit silently
if [ -f "$LOCK_FILE" ]; then
    OLD_PID=$(cat "$LOCK_FILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        exit 0
    fi
fi

# 3️⃣ Register current process as the single instance
mkdir -p "$LOCK_DIR"
echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT
### ============================

. /data/adb/modules/MTK_AI/MTK_AI/AI_MODE/auto_frequency/auto_frequency

MOD_DIR="/data/adb/modules/MTK_AI"
EXTERNAL_CFG="/sdcard/MTK_AI_Engine"
STATE_DIR="$LOCK_DIR"

TRIMMING_PATH="$MOD_DIR/MTK_AI/AI_MODE/global_mode/trim_memory"
RAM_CLEANER_PATH="$MOD_DIR/MTK_AI/AI_MODE/global_mode/ram_cleaner"
MODULE_EXECUTER="$MOD_DIR/MTK_AI/AI_MODE/global_mode/module_executer"
LOGIC_CPU7_PATH="$MOD_DIR/MTK_AI/AI_MODE/auto_frequency/cpu7"
LOGIC_CPU6_PATH="$MOD_DIR/MTK_AI/AI_MODE/auto_frequency/cpu6"

chmod +x "$TRIMMING_PATH" "$RAM_CLEANER_PATH" \
        "$LOGIC_CPU6_PATH" "$LOGIC_CPU7_PATH" \
        "$MODULE_EXECUTER" 2>/dev/null

nohup sh "$MOD_DIR/script_runner/boost_color_apply.sh" >/dev/null 2>&1 &
nohup sh "$MOD_DIR/script_runner/mtk_ai_manual" >/dev/null 2>&1 &
nohup sh "$MOD_DIR/service.d/backup.sh" >/dev/null 2>&1 &
nohup sh "$MOD_DIR/update_checker.sh" >/dev/null 2>&1 &

if [ -f "$EXTERNAL_CFG/low_power_mode" ]; then
    nohup "$MOD_DIR/MTK_AI/AI_MODE/normal_mode/powersavex" >/dev/null 2>&1 &
fi

if [ -f "$EXTERNAL_CFG/enable_fastcharge" ]; then
    export LD_LIBRARY_PATH="/data/adb/modules/MTK_AI/lib64:$LD_LIBRARY_PATH"
    nohup "$MOD_DIR/MTK_AI/AI_MODE/global_mode/heartbeat" >/dev/null 2>&1 &
fi

FAST_REBOOT_FLAG="$EXTERNAL_CFG/fast_reboot_enabled"

if [ -f "$FAST_REBOOT_FLAG" ]; then
    log_msg "Fast reboot enabled, applying safe optimizations"
    setprop debug.sf.nobootanimation 1
    setprop persist.sys.mtk.fast_boot 1 2>/dev/null
    setprop ro.config.fastboot 1 2>/dev/null
    setprop ro.zygote.disable_gl_preload 1 2>/dev/null
    setprop pm.dexopt.bg-dexopt verify
    log_msg "Fast reboot mode active (dex2oat-safe)"
else
    log_msg "Fast reboot flag not found, skipping"
fi

run_cmd() {
    if [ -f "$EXTERNAL_CFG/enable_trim" ]; then
        pgrep -f "trim_memory" > /dev/null || nohup sh "$TRIMMING_PATH" 2>&1 &
    else
        pkill -f "trim_memory" 2>/dev/null
    fi

    if [ -f "$EXTERNAL_CFG/enable_cleaner" ]; then
        pgrep -f "ram_cleaner" > /dev/null || nohup sh "$RAM_CLEANER_PATH" 2>&1 &
    else
        pkill -f "ram_cleaner" 2>/dev/null
    fi

    if [ -f "$EXTERNAL_CFG/enable_cpu" ]; then
        pgrep -f "cpu6" > /dev/null || nohup sh "$LOGIC_CPU6_PATH" 2>&1 &
        pgrep -f "cpu7" > /dev/null || nohup sh "$LOGIC_CPU7_PATH" 2>&1 &
    else
        pkill -f "cpu6" 2>/dev/null
        pkill -f "cpu7" 2>/dev/null
    fi

    if [ -f "$EXTERNAL_CFG/enable_module" ]; then
        pgrep -f "module_executer" 2>/dev/null | grep -vw "$$" | while read -r pid; do
            kill -9 "$pid" 2>/dev/null
        done
        sleep 0.2
        export PATH="/system/bin:/system/xbin:/sbin:/vendor/bin"
        cd "$MOD_DIR" || exit 1
        nohup sh "$MODULE_EXECUTER" >/dev/null 2>&1 &
    else
        pkill -f "module_executer" 2>/dev/null
    fi
}

find_touchscreen() {
    for dev in /dev/input/event*; do
        if getevent -p "$dev" 2>/dev/null | grep -q "0035"; then
            echo "$dev"
            return 0
        fi
    done
}

TIMEOUT=5
F="/sdcard/MTK_AI_Engine/touch_timeout.txt"

[ -f "$F" ] && T=$(tr -d ' \r\n' < "$F") && [ "$T" -eq "$T" ] 2>/dev/null && TIMEOUT=$T

# Initial State
LAST_ACTIVITY=$(date +%s)
STATE="PERF"

# 🔧 FIX #3: resolve touchscreen device ONCE before the loop
TS_DEV=$(find_touchscreen)
if [ -z "$TS_DEV" ]; then
    log_msg "WARNING: No touchscreen device found — idle detection disabled"
fi

while true; do
    if [ -n "$TS_DEV" ] && timeout 1s getevent -c 1 "$TS_DEV" > /dev/null 2>&1; then
        LAST_ACTIVITY=$(date +%s)
        if [ "$STATE" = "SAVE" ]; then
            STATE="PERF"
            touch_active
            run_cmd
            # 🔧 FIX: Skip current_app if automode is "1"
            if [ ! -f "$EXTERNAL_CFG/automode" ] || [ "$(cat "$EXTERNAL_CFG/automode" 2>/dev/null)" != "1" ]; then
                current_app
            fi
        fi
    else
        NOW=$(date +%s)
        ELAPSED=$((NOW - LAST_ACTIVITY))

        if [ "$ELAPSED" -ge "$TIMEOUT" ] && [ "$STATE" = "PERF" ]; then
            STATE="SAVE"
            touch_inactive
            run_cmd
            # 🔧 FIX: Skip current_app if automode is "1"
            if [ ! -f "$EXTERNAL_CFG/automode" ] || [ "$(cat "$EXTERNAL_CFG/automode" 2>/dev/null)" != "1" ]; then
                current_app
            fi
        fi
    fi

    CUR_TIME=$(date +%s)
    DIFF=$((CUR_TIME - LAST_ACTIVITY))
    printf "\r[Mode: %s] [Idle: %ds]    " "$STATE" "$DIFF"
    sleep 1
done
