#!/system/bin/sh
### === SINGLE INSTANCE LOCK ===
LOCK_DIR="/data/adb/modules/MTK_AI/.guard"
mkdir -p "$LOCK_DIR"
LOCK_FILE="$LOCK_DIR/global_runner.pid"

# If PID file exists and process is alive → exit silently
if [ -f "$LOCK_FILE" ]; then
    OLD_PID=$(cat "$LOCK_FILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        exit 0
    fi
fi

# Register current process as the single instance
echo $$ > "$LOCK_FILE"
# Auto-clean PID file on normal exit or SIGTERM
trap 'rm -f "$LOCK_FILE"' EXIT
### ============================

MOD_DIR="/data/adb/modules/MTK_AI"
EXTERNAL_CFG="/sdcard/MTK_AI_Engine"
STATE_DIR="$LOCK_DIR" # Reuse lock dir for internal state files

TRIMMING_PATH="$MOD_DIR/MTK_AI/AI_MODE/global_mode/trim_memory"
RAM_CLEANER_PATH="$MOD_DIR/MTK_AI/AI_MODE/global_mode/ram_cleaner"
MODULE_EXECUTER="$MOD_DIR/MTK_AI/AI_MODE/global_mode/module_executer"
LOGIC_CPU7_PATH="$MOD_DIR/MTK_AI/AI_MODE/auto_frequency/cpu7"
LOGIC_CPU6_PATH="$MOD_DIR/MTK_AI/AI_MODE/auto_frequency/cpu6"

# Ensure permissions (RESOURCES_PATH removed: undefined in your snippet)
chmod +x "$TRIMMING_PATH"
chmod +x "$RAM_CLEANER_PATH"
chmod +x "$LOGIC_CPU6_PATH"
chmod +x "$LOGIC_CPU7_PATH"
chmod +x "$MODULE_EXECUTER"

sh "/data/adb/modules/MTK_AI/script_runner/boost_color_apply.sh"

FAST_REBOOT_FLAG="/sdcard/MTK_AI_Engine/fast_reboot_enabled"

if [ -f "$FAST_REBOOT_FLAG" ]; then
    log "MTK_AI: Fast reboot enabled, applying safe optimizations"

    # 1. Skip boot animation (safe, works on all Android)
    setprop debug.sf.nobootanimation 1

    # 2. MTK/Transsion fast boot props (if supported by your ROM)
    setprop persist.sys.mtk.fast_boot 1 2>/dev/null
    setprop ro.config.fastboot 1 2>/dev/null

    # 3. Reduce Zygote preload timeout (speeds up app launch)
    setprop ro.zygote.disable_gl_preload 1 2>/dev/null

    # 4. Skip background dexopt during THIS boot only (prevents boot slowdown)
    #    Does NOT break pm compile or user-triggered dexopt
    setprop pm.dexopt.bg-dexopt verify

    log "MTK_AI: Fast reboot mode active (dex2oat-safe)"
else
    log "MTK_AI: Fast reboot flag not found, skipping"
fi

while true; do
    # Logic for Trim Memory
    if [ -f "$EXTERNAL_CFG/enable_trim" ]; then
        pgrep -f "trim_memory" > /dev/null || "$TRIMMING_PATH" &
    else
        pkill -f "trim_memory"
    fi

    # Logic for RAM Cleaner
    if [ -f "$EXTERNAL_CFG/enable_cleaner" ]; then
        pgrep -f "ram_cleaner" > /dev/null || "$RAM_CLEANER_PATH" &
    else
        pkill -f "ram_cleaner"
    fi
    # Logic for CPU6
    if [ -f "$EXTERNAL_CFG/enable_cpu" ]; then
        pgrep -f "cpu6" > /dev/null || "$LOGIC_CPU6_PATH" &
    else
        pkill -f "cpu6"
    fi

    # Logic for CPU7
    if [ -f "$EXTERNAL_CFG/enable_cpu" ]; then
        pgrep -f "cpu7" > /dev/null || "$LOGIC_CPU7_PATH" &
    else
        pkill -f "cpu7"
    fi

    # Logic for MODULE_EXECUTER
    if [ -f "$EXTERNAL_CFG/enable_module" ]; then
        pgrep -f "module_executer" > /dev/null || "$MODULE_EXECUTER" &
    else
        pkill -f "module_executer"
    fi

    # Wait for 30 seconds before running again
    sleep 30
done
