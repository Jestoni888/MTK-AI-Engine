#!/system/bin/sh
### ==== FLOOD GUARD BEGIN ==== ###

SCRIPT_NAME="$(basename "$0")"
STATE_DIR="/data/adb/modules/MTK_AI/.guard"
mkdir -p "$STATE_DIR"

RUN_TS_FILE="$STATE_DIR/${SCRIPT_NAME}.last"
COUNT_FILE="$STATE_DIR/${SCRIPT_NAME}.count"

NOW=$(date +%s)
LAST=$(cat "$RUN_TS_FILE" 2>/dev/null || echo 0)
COUNT=$(cat "$COUNT_FILE" 2>/dev/null || echo 0)

# --- rate limits ---
MIN_INTERVAL=5
MAX_RUNS=5
WINDOW=60

[ $((NOW - LAST)) -lt $MIN_INTERVAL ] && exit 0

if [ $((NOW - LAST)) -lt $WINDOW ]; then
  COUNT=$((COUNT + 1))
else
  COUNT=1
fi

if [ "$COUNT" -gt "$MAX_RUNS" ]; then
  echo "[FLOOD-GUARD] $SCRIPT_NAME blocked" \
    >> /sdcard/MTK_AI_Engine/flood_guard.log 2>/dev/null
  exit 0
fi

echo "$NOW" > "$RUN_TS_FILE"
echo "$COUNT" > "$COUNT_FILE"

### ==== FLOOD GUARD END ==== ###

# -------------------------
# CONFIGURATION & LOGGING
# -------------------------
LOG_DIR="/sdcard/MTK_AI_Engine"
CONFIG_DIR="$LOG_DIR/config"
mkdir -p "$CONFIG_DIR"
LOG_FILE="$LOG_DIR/MTK_AI_Engine.log"

RAM_THRESHOLD_FILE="$CONFIG_DIR/ram_threshold.txt"
FORCE_KILL_FILE="$CONFIG_DIR/force_kill.list"
NEVER_KILL_FILE="$CONFIG_DIR/never_kill.list"
# Initialize config files if missing (WebUI can overwrite these later)
[ -f "$RAM_THRESHOLD_FILE" ] || echo "50" > "$RAM_THRESHOLD_FILE"
[ -f "$FORCE_KILL_FILE" ] || printf "# Force Kill List\n# Packages here are ALWAYS killed when background (bypasses all protections)\n# One package per line\n" > "$FORCE_KILL_FILE"
[ -f "$NEVER_KILL_FILE" ] || printf "# Never Kill List\n# Packages here are NEVER killed (always protected)\n# One package per line\n" > "$NEVER_KILL_FILE"

load_configs() {
    # Load RAM Threshold
    RAM_THRESHOLD=$(cat "$RAM_THRESHOLD_FILE" 2>/dev/null | tr -d '[:space:]')
    echo "$RAM_THRESHOLD" | grep -qE '^[0-9]+$' || RAM_THRESHOLD=50

    # Load Lists (strip comments & whitespace)
    FORCE_KILL_LIST=$(grep -v '^#' "$FORCE_KILL_FILE" 2>/dev/null | grep -v '^[[:space:]]*$' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    NEVER_KILL_LIST=$(grep -v '^#' "$NEVER_KILL_FILE" 2>/dev/null | grep -v '^[[:space:]]*$' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
}

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
    [ "$(wc -l < "$LOG_FILE")" -gt 200 ] &&
        tail -n 200 "$LOG_FILE" > "$LOG_FILE.tmp" &&
        mv "$LOG_FILE.tmp" "$LOG_FILE"
}

# -------------------------
# PACKAGE HELPERS
# -------------------------
get_installed_packages() {
    pm list packages 2>/dev/null | cut -d':' -f2 | sort -u
}

is_package_installed() {
    echo "$INSTALLED_PACKAGES" | grep -qx "$1"
}

extract_package_from_cmdline() {
    local cmdline="$1"
    local pkg=$(echo "$cmdline" | grep -oiE '(com|org|net|io)\.[a-z0-9_.]+' | head -1)
    if [ -z "$pkg" ]; then
        pkg=$(echo "$cmdline" | grep -oE '[a-z0-9_.]+/[A-Za-z0-9_.]+' | head -1 | cut -d'/' -f1)
    fi
    if [ -z "$pkg" ]; then
        pkg=$(echo "$cmdline" | grep -oE '[a-z][a-z0-9_]*\.[a-z][a-z0-9_.]+' | head -1)
    fi
    echo "$pkg"
}

# -------------------------
# ACCURATE BACKGROUND KILLER
# -------------------------
force_kill_cgroup_safe() {
    log_msg "🕵️ Loading configs & building package list..."    load_configs
    INSTALLED_PACKAGES=$(get_installed_packages)
    
    log_msg "🕵️ Scanning /dev/cpuset/background/cgroup.procs..."
    
    local PIDS_FILE="/tmp/bg_pids_$$.txt"
    cat /dev/cpuset/background/cgroup.procs > "$PIDS_FILE" 2>/dev/null
    
    if [ ! -s "$PIDS_FILE" ]; then
        log_msg " Background CGroup is empty."
        rm -f "$PIDS_FILE"
        return
    fi

    local killed_count=0
    local protected_count=0
    local skipped_count=0

    while read -r pid; do
        [ -z "$pid" ] && continue
        
        local proc_name=$(ps -o comm= -p "$pid" 2>/dev/null | tr -d ' ')
        [ -z "$proc_name" ] && continue

        local pkg=""
        if [ "$proc_name" = "app_process" ] || [ "$proc_name" = "app_process64" ]; then
            local cmdline=$(cat /proc/$pid/cmdline 2>/dev/null | tr '\0' ' ')
            pkg=$(extract_package_from_cmdline "$cmdline")
        elif echo "$proc_name" | grep -qE '\.'; then
            pkg="$proc_name"
        else
            local cmdline=$(cat /proc/$pid/cmdline 2>/dev/null | tr '\0' ' ')
            pkg=$(extract_package_from_cmdline "$cmdline")
        fi

        # Validate package format
        if [ -z "$pkg" ] || ! echo "$pkg" | grep -qE '^[a-z][a-z0-9_]*(\.[a-z0-9_]+)+'; then
            skipped_count=$((skipped_count + 1))
            continue
        fi

        # 1. NEVER KILL LIST (Highest Priority Protection)
        if [ -n "$NEVER_KILL_LIST" ] && echo "$NEVER_KILL_LIST" | grep -qx "$pkg"; then
            log_msg "   🛡️ NEVER KILL: $pkg (PID: $pid)"
            protected_count=$((protected_count + 1))
            continue
        fi

        # 2. FORCE KILL LIST (Bypasses all other checks)
        if [ -n "$FORCE_KILL_LIST" ] && echo "$FORCE_KILL_LIST" | grep -qx "$pkg"; then            log_msg "   ⚡ FORCE KILL: $pkg (PID: $pid)"
            am force-stop "$pkg" 2>/dev/null
            sleep 0.5
            if ps -p "$pid" >/dev/null 2>&1; then kill -9 "$pid" 2>/dev/null; fi
            killed_count=$((killed_count + 1))
            continue
        fi

        # 3. Standard Safety Checks
        if ! is_package_installed "$pkg"; then
            skipped_count=$((skipped_count + 1))
            continue
        fi

        local adj=$(cat /proc/$pid/oom_score_adj 2>/dev/null)
        if [ -n "$adj" ] && [ "$adj" -lt 900 ]; then
            skipped_count=$((skipped_count + 1))
            continue
        fi

        case "$pkg" in
            android.hardware.*|android.system.*|vendor.*|com.android.systemui|com.google.android.gms|com.google.android.gsf|com.android.phone|com.android.settings|com.android.launcher3|com.google.android.inputmethod.latin|android|bluetooth|com.google.android.webview)
                log_msg "   🛡️ Protected System: $pkg (PID: $pid)"
                protected_count=$((protected_count + 1))
                continue
                ;;
        esac

        # --- STANDARD KILL ---
        log_msg "   🎯 Killing: $pkg (PID: $pid adj: ${adj:-?})"
        am force-stop "$pkg" 2>/dev/null
        sleep 0.5
        
        if ps -p "$pid" >/dev/null 2>&1; then
            log_msg "   ⚠️ Force-stop failed, using SIGKILL..."
            kill -9 "$pid" 2>/dev/null
            sleep 0.3
            if ps -p "$pid" >/dev/null 2>&1; then
                log_msg "   ❌ FAILED: $pkg (PID: $pid)"
            else
                log_msg "   ✅ Killed via SIGKILL: $pkg"
                killed_count=$((killed_count + 1))
            fi
        else
            log_msg "   ✅ Killed via am force-stop: $pkg"
            killed_count=$((killed_count + 1))
        fi
        
        sleep 0.2
    done < "$PIDS_FILE"
    rm -f "$PIDS_FILE"
    log_msg "✅ Cleanup Finished: $killed_count killed, $protected_count protected, $skipped_count skipped"
}

# -------------------------
# MAIN RAM FOCUS LOOP
# -------------------------
auto_focus_ram() {
    # Reload configs every cycle so WebUI changes apply immediately
    load_configs
    
    local MEM_TOTAL=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    local MEM_AVAIL_START=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
    local MEM_USED_PCT=$(((MEM_TOTAL - MEM_AVAIL_START) * 100 / MEM_TOTAL))

    log_msg "️ RAM Check: ${MEM_USED_PCT}% usage (Threshold: ${RAM_THRESHOLD}%)"

    if [ "$MEM_USED_PCT" -gt "$RAM_THRESHOLD" ]; then
        log_msg "🚨 High RAM usage! Prioritizing Foreground/Top-App..."
        force_kill_cgroup_safe

        sync
        echo 3 > /proc/sys/vm/drop_caches
        echo 1 > /proc/sys/vm/compact_memory

        local MEM_AVAIL_END=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
        local FREED=$(((MEM_AVAIL_END - MEM_AVAIL_START) / 1024))
        log_msg "✅ RAM Focused. Freed ${FREED}MB. Foreground protected."
    fi
}

log_msg "🚀 RAM Focus Service Started (Config: $CONFIG_DIR)"

while true; do
    auto_focus_ram    
    sleep 60
done
