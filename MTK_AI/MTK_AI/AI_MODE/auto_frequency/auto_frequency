#!/system/bin/sh

# LITE MODE

MOD_DIR="/data/adb/modules/MTK_AI"
BB="$MOD_DIR/busybox"
EXTERNAL_CFG="/sdcard/MTK_AI_Engine"
NOTIFY_ENABLED_FILE="$EXTERNAL_CFG/enable_notifications"
TOUCH_ACTIVE="$EXTERNAL_CFG/enable_limiter"

# --- NOTIFICATION FUNCTION ---
# Uses UID 2000 to bypass SELinux restrictions
notify_status() {
# Skip if notification toggle is OFF
    [ ! -f "$NOTIFY_ENABLED_FILE" ] && return 0
    # --- 1. Temperature ---
    RAW_TEMP=$(cat /sys/class/power_supply/battery/temp 2>/dev/null || echo "0")
    B_TEMP="$((RAW_TEMP / 10)).$((RAW_TEMP % 10))°C"

    # --- 2. Governor ---
    GOV_FILE="/sys/devices/system/cpu/cpufreq/policy0/scaling_governor"
    [ ! -f "$GOV_FILE" ] && GOV_FILE="/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor"
    CPU_GOV="Unknown"
    [ -f "$GOV_FILE" ] && CPU_GOV=$(cat "$GOV_FILE" 2>/dev/null | tr -d '[:space:]')

    # --- 3. Power Calculation (FIXED FOR LARGE NUMBERS) ---
    VOLT_FILE="/sys/class/power_supply/battery/voltage_now"
    CURR_FILE="/sys/class/power_supply/battery/current_now"
    [ ! -f "$VOLT_FILE" ] && VOLT_FILE="/sys/class/power_supply/bms/voltage_now"
    [ ! -f "$CURR_FILE" ] && CURR_FILE="/sys/class/power_supply/bms/current_now"

    POWER_WATTS="N/A"

    if [ -f "$VOLT_FILE" ] && [ -f "$CURR_FILE" ]; then
        VOLT=$(cat "$VOLT_FILE" 2>/dev/null | tr -d '[:space:]')
        CURR=$(cat "$CURR_FILE" 2>/dev/null | tr -d '[:space:]')

        # FIX: Divide inputs by 1,000,000 FIRST to get Volts and Amps.
        # Then multiply. This prevents integer overflow in awk.
        POWER_WATTS=$(awk -v v="$VOLT" -v c="$CURR" 'BEGIN {
            # Convert micro-units to base units immediately
            volts = v / 1000000
            amps = c / 1000000
            
            # Make amps positive
            if (amps < 0) amps = -amps
            
            # Calculate Watts
            val = volts * amps
            
            # Sanity Check (0.01W to 60W)
            if (val >= 0.01 && val <= 60) {
                printf "%.2fW", val
            } else {
                print "N/A"
            }
        }')
    fi

    local status_msg="$1"
    local full_msg="$status_msg | Gov: $CPU_GOV | Pwr: $POWER_WATTS | Temp: $B_TEMP"

    su -lp 2000 -c "cmd notification post -I /data/adb/modules/MTK_AI/icon.png -S bigtext -t 'Lite mode' tag '$full_msg'" >/dev/null 2>&1
}

touch_active() {
[ ! -f "$TOUCH_ACTIVE" ] && return 0
ps 2>/dev/null | grep -v grep | grep -qw "mtk_ai_engine" && return 0

    CPU_SYS="/sys/devices/system/cpu"
    
    # Tune schedutil for faster response
    for p in $CPU_SYS/cpufreq/policy*; do
        [ -d "$p" ] || continue
        [ -w "$p/schedutil/rate_limit_us" ] && echo 100 > "$p/schedutil/rate_limit_us"
    done

    # Replace the existing frequency setting with:
TOUCH_ACTIVE_PERCENT=100
if [ -f "/sdcard/MTK_AI_Engine/manual_touch_active_freq.txt" ]; then
    TOUCH_ACTIVE_PERCENT=$(cat "/sdcard/MTK_AI_Engine/manual_touch_active_freq.txt" | tr -d '\r\n ')
    # Validate range
    if [ "$TOUCH_ACTIVE_PERCENT" -lt 50 ] 2>/dev/null; then TOUCH_ACTIVE_PERCENT=50; fi
    if [ "$TOUCH_ACTIVE_PERCENT" -gt 100 ] 2>/dev/null; then TOUCH_ACTIVE_PERCENT=100; fi
fi

# --- 5. REFRESH RATE ---
            REFRESH_FILE="/sdcard/MTK_AI_Engine/manual_refresh_lock.txt"
            if [ -f "$REFRESH_FILE" ]; then
                MODE_ID=$(tr -d '\r\n\t ' < "$REFRESH_FILE")
                if [ -n "$MODE_ID" ] && [ "$MODE_ID" -eq "$MODE_ID" ] 2>/dev/null; then
                    service call SurfaceFlinger 1035 i32 "$MODE_ID" >/dev/null 2>&1 && \
                        log_msg "🖥️ Refresh Rate: mode $MODE_ID"
                fi
            fi

for cpu in $CPU_SYS/cpu[0-9]*; do
    MAX_FREQ=$(cat "$cpu/cpufreq/cpuinfo_max_freq")
    MIN_FREQ=$(cat "$cpu/cpufreq/cpuinfo_min_freq")
    TARGET_MAX=$((MAX_FREQ * TOUCH_ACTIVE_PERCENT / 100))
    chmod 644 "$cpu/cpufreq/scaling_min_freq"
    chmod 644 "$cpu/cpufreq/scaling_max_freq" 
    echo "$MIN_FREQ" > "$cpu/cpufreq/scaling_min_freq"
    echo "$TARGET_MAX" > "$cpu/cpufreq/scaling_max_freq"
done

sync

[ "$(id -u)" -ne 0 ] && exit 1
OPP=$(cat /sdcard/MTK_AI_Engine/global_gpu_opp_index.txt 2>/dev/null) || OPP=0
[ "$OPP" -lt 0 ] || [ "$OPP" -gt 32 ] && OPP=0
echo $OPP > /proc/gpufreqv2/fix_target_opp_index
}

touch_inactive() {
[ ! -f "$TOUCH_ACTIVE" ] && return 0
ps 2>/dev/null | grep -v grep | grep -qw "mtk_ai_engine" && return 0
echo 32 > /proc/gpufreqv2/fix_target_opp_index

    su -c "service call SurfaceFlinger 1035 i32 2" 2>/dev/null

    # Read saved Inactive CPU % from SD card
    INACTIVE_PERCENT=30
    if [ -f "/sdcard/MTK_AI_Engine/manual_inactive_freq.txt" ]; then
        INACTIVE_PERCENT=$(cat "/sdcard/MTK_AI_Engine/manual_inactive_freq.txt" | tr -d '\r\n ')
        # Enforce 25-50% range
        if [ "$INACTIVE_PERCENT" -lt 25 ] 2>/dev/null; then
            INACTIVE_PERCENT=25
        elif [ "$INACTIVE_PERCENT" -gt 50 ] 2>/dev/null; then
            INACTIVE_PERCENT=50
        fi
    fi

    for policy in $CPU_SYS/cpufreq/policy*; do
        [ -d "$policy" ] || continue
        
        if [ -f "$policy/cpuinfo_max_freq" ]; then
            max_val=$(cat "$policy/cpuinfo_max_freq")
            target_val=$(( max_val * INACTIVE_PERCENT / 100 ))
            
            chmod 644 "$policy/scaling_max_freq" 2>/dev/null
            echo "$target_val" > "$policy/scaling_max_freq"
        fi
    done

    sync
}

force_kill() {
CONFIG_DIR="/sdcard/MTK_AI_Engine/config"
FORCE_KILL_FILE="${CONFIG_DIR}/force_kill.list"
NEVER_KILL_FILE="${CONFIG_DIR}/never_kill.list"

# Critical apps that must NEVER be killed (from hibernator.js)
CRITICAL_APPS="
com.android.systemui
com.android.phone
com.android.stk
com.google.android.gms
com.google.android.gsf
com.google.android.packageinstaller
com.android.settings
com.google.android.setupwizard
com.android.launcher3
com.google.android.inputmethod.latin
android
com.android.providers.settings
com.android.providers.downloads
com.android.providers.media.module
com.android.externalstorage
com.android.documentsui
com.android.permissioncontroller
com.android.vending
com.google.android.webview
"

# Critical prefixes (apps starting with these are protected)
CRITICAL_PREFIXES="android.hardware. android.system. vendor. com.android.system"

mkdir -p "$CONFIG_DIR"

is_critical() {
    local pkg="$1"
    # Check exact match
    for critical in $CRITICAL_APPS; do
        [ "$pkg" = "$critical" ] && return 0
    done
    # Check prefix match
    for prefix in $CRITICAL_PREFIXES; do
        case "$pkg" in
            ${prefix}*) return 0 ;;
        esac
    done
    return 1
}

get_current_app() {
    # 🎯 Extract current top app package name
    local top_app=$(dumpsys window 2>/dev/null | grep -m1 'mCurrentFocus' | sed -E 's/.* ([^ /]+)\/.*/\1/')
    
    # ✅ Validate package name format (allows uppercase)
    if echo "$top_app" | grep -qE '^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+$'; then
        echo "$top_app"
    fi
}

echo "📦 Fetching installed packages..."
ALL_PACKAGES=$(pm list packages 2>/dev/null | cut -d: -f2 | sort -u)

if [ -z "$ALL_PACKAGES" ]; then
    echo "❌ Failed to get package list. Are you root?"
    exit 1
fi

TOTAL=$(echo "$ALL_PACKAGES" | wc -l)
echo "📊 Total installed packages: $TOTAL"

# Detect current top app
echo "🎯 Detecting current top app..."
CURRENT_APP=$(get_current_app)
if [ -n "$CURRENT_APP" ]; then
    echo "✅ Current top app: $CURRENT_APP"
else
    echo "⚠️ Could not detect current top app"
fi

# Initialize lists
FORCE_LIST=""
NEVER_LIST=""
ADDED_FORCE=0
SKIPPED=0

# 1. Add current app to Never Kill list (if it's not a critical system app)
if [ -n "$CURRENT_APP" ] && ! is_critical "$CURRENT_APP"; then
    NEVER_LIST="$CURRENT_APP"
    echo "🛡️ Added current app to Never Kill list: $CURRENT_APP"
fi

# 2. Add all non-critical apps to Force Kill list
for pkg in $ALL_PACKAGES; do
    pkg=$(echo "$pkg" | tr -d '[:space:]')
    [ -z "$pkg" ] && continue

    # Skip current app (already handled in never_kill)
    [ "$pkg" = "$CURRENT_APP" ] && continue

    if is_critical "$pkg"; then
        SKIPPED=$((SKIPPED + 1))
    else
        if [ -z "$FORCE_LIST" ]; then
            FORCE_LIST="$pkg"
        else
            FORCE_LIST="${FORCE_LIST}
${pkg}"
        fi
        ADDED_FORCE=$((ADDED_FORCE + 1))
    fi
done

# Write files
echo "$FORCE_LIST" > "$FORCE_KILL_FILE"
echo "⚡ Added $ADDED_FORCE apps to Force Kill list"

if [ -n "$NEVER_LIST" ]; then
    echo "$NEVER_LIST" > "$NEVER_KILL_FILE"
else
    # If no current app was added, clear the file since all non-critical 
    # apps are now in force_kill (mirrors JS bulk action behavior)
    echo "" > "$NEVER_KILL_FILE"
fi

touch /sdcard/MTK_AI_Engine/enable_cleaner

echo "🛡️ Skipped $SKIPPED critical system apps"
echo "✅ Done! Configs saved to $CONFIG_DIR"
}

game_mode() {
if [ -f "$EXTERNAL_CFG/use_tweaks" ]; then
force_kill
nohup sh "/data/adb/modules/MTK_AI/MTK_AI/AI_MODE/gaming_mode/app_optimizer" >/dev/null 2>&1 &
fi
if [ -f "$EXTERNAL_CFG/enable_gaming_prop" ]; then
    nohup "$MOD_DIR/MTK_AI/AI_MODE/gaming_mode/gaming_prop" >/dev/null 2>&1 &
fi
if [ -f "$EXTERNAL_CFG/enable_gaming_prop2" ]; then
    nohup "$MOD_DIR/MTK_AI/AI_MODE/gaming_mode/gaming_prop_2" >/dev/null 2>&1 &
fi
if [ -f "$EXTERNAL_CFG/enable_disable_thermal" ]; then
    nohup "$MOD_DIR/MTK_AI/AI_MODE/gaming_mode/disable_thermal" >/dev/null 2>&1 &
fi
if [ -f "$EXTERNAL_CFG/enable_performance" ]; then
    nohup "$MOD_DIR/MTK_AI/AI_MODE/gaming_mode/performance" >/dev/null 2>&1 &
fi

[ "$(cat "/sdcard/MTK_AI_Engine/current_profile" 2>/dev/null | tr -d '[:space:]')" != "powersave" ] && return 0
rm -f /sdcard/MTK_AI_Engine/enable_limiter
}

normal_mode() {
if [ -f "$EXTERNAL_CFG/use_tweaks" ]; then
nohup sh "/data/adb/modules/MTK_AI/MTK_AI/AI_MODE/normal_mode/normal_prop" >/dev/null 2>&1 &
nohup sh "/data/adb/modules/MTK_AI/MTK_AI/AI_MODE/normal_mode/normal_cpuset" >/dev/null 2>&1 &
fi
[ "$(cat "/sdcard/MTK_AI_Engine/current_profile" 2>/dev/null | tr -d '[:space:]')" != "powersave" ] && return 0
touch /sdcard/MTK_AI_Engine/enable_limiter 2>/dev/null 
echo "1" > /sdcard/MTK_AI_Engine/enable_limiter 2>/dev/null
}

# 🏠 Helper: Check if package is a launcher (home screen)
is_launcher() {
    local pkg="$1"
    case "$pkg" in
        com.android.launcher*|\
        com.google.android.launcher*|\
        com.google.android.apps.nexuslauncher|\
        com.miui.home|\
        com.sec.android.app.launcher|\
        com.sonyericsson.home|\
        com.lge.launcher*|\
        com.huawei.android.launcher|\
        com.transsion.launcher*|\
        com.oppo.launcher|\
        com.coloros.launcher|\
        com.oneplus.launcher|\
        com.teslacoilsw.launcher|\
        org.lineageos.trebuchet|\
        com.android.launcher3|\
        com.pixelstar.launcher|\
        com.tcl.launcher|\
        com.vivo.launcher)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

current_app() {
    # 🎮 STATE CHECK: If gaming mode is already active, skip full detection
    if [ -f /dev/.mtk_ai_active_game ]; then
        CURRENT_TOP_APP=$(dumpsys window 2>/dev/null | grep -m1 'mCurrentFocus' | sed -E 's/.* ([^ /]+)\/.*/\1/')
        
        # ✅ FIXED: Allow uppercase letters in package validation
        if echo "$CURRENT_TOP_APP" | grep -qE '^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+$'; then
            if is_launcher "$CURRENT_TOP_APP"; then
                log_msg "🏠 Launcher detected, exiting gaming mode"
                rm -f /dev/.mtk_ai_active_game
                normal_mode
                notify_status "Normal mode: $CURRENT_TOP_APP"
            fi
        fi
        return 0
    fi
    
    # 📱 Not in gaming mode: run full detection ONCE
    log_msg "📱 Detecting current top app..."
    CURRENT_TOP_APP=$(dumpsys window 2>/dev/null | grep -m1 'mCurrentFocus' | sed -E 's/.* ([^ /]+)\/.*/\1/')
    
    # ✅ FIXED: Allow uppercase letters in package validation
    if ! echo "$CURRENT_TOP_APP" | grep -qE '^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+$'; then
        CURRENT_TOP_APP=""
        notify_status "⚠️"
        return 0
    fi
    
    notify_status "$CURRENT_TOP_APP"
    
    # Check if current app is a game
    if awk -v pkg="$CURRENT_TOP_APP" '{ gsub(/\r/, ""); if ($0 == pkg) { found=1; exit } } END { exit !found }' /sdcard/MTK_AI_Engine/game_list.txt 2>/dev/null; then
        echo "$CURRENT_TOP_APP" > /dev/.mtk_ai_active_game 2>/dev/null
        game_mode
        notify_status "Gaming🎮: $CURRENT_TOP_APP"
    fi
}
