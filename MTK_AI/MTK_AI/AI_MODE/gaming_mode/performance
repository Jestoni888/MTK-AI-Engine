#!/system/bin/sh

# Maximum Performance Script — Final Version
# Based on your kr-script/mtk XML logic
# Targets: mt6983, mt6895, and gpufreqv2-based Dimensity SoCs

# ⚠️ Removed `set -e` to guarantee continuation on failure.
# Added `|| true` to all critical writes to enforce "skip if fail" behavior.

echo "[+] Applying MAXIMUM PERFORMANCE CONFIG..."

# --- CPU & Governor Tweaks ---
echo performance > /sys/class/devfreq/13000000.mali/governor 2>/dev/null || true
echo performance > /sys/class/devfreq/mtk-dvfsrc-devfreq/governor 2>/dev/null || true

for c in /sys/devices/system/cpu/cpu*/core_ctl/enable; do
  echo 0 > "$c" 2>/dev/null || true
done

echo 1 > /sys/devices/system/cpu/sched/sched_boost 2>/dev/null || true
echo 1 > /sys/devices/system/cpu/eas/enable 2>/dev/null || true
echo 536870911 > /sys/kernel/fpsgo/common/systrace_mask 2>/dev/null || true

chmod 777 /sys/devices/system/cpu/cpufreq/policy* 2>/dev/null || true
for policy in /sys/devices/system/cpu/cpufreq/policy*; do 
  chmod 777 "$policy/scaling_governor" 2>/dev/null || true
  echo performance > "$policy/scaling_governor" 2>/dev/null || true
done

chmod 777 /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_max_freq 2>/dev/null || true
chmod 777 /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_min_freq 2>/dev/null || true

for d in /sys/devices/system/cpu/cpu[0-9]*/cpufreq; do
  [ -d "$d" ] || continue
  H_MAX=$(cat "$d/cpuinfo_max_freq" 2>/dev/null) || continue
  H_MIN=$(cat "$d/cpuinfo_min_freq" 2>/dev/null) || echo 0
  [ -n "$H_MAX" ] && { echo "$H_MAX" > "$d/scaling_max_freq" 2>/dev/null || true; echo "$H_MIN" > "$d/scaling_min_freq" 2>/dev/null || true; }
done

echo 0 > /proc/gpufreqv2/fix_target_opp_index 2>/dev/null || true
echo 0 > /proc/gpufreq/gpufreq_opp_dump 2>/dev/null || true

for cpu in /sys/devices/system/cpu/cpu[0-9]*; do 
  [ -f "$cpu/cpufreq/scaling_max_freq" ] && cat "$cpu/cpufreq/scaling_max_freq" > "$cpu/cpufreq/scaling_min_freq" 2>/dev/null || true
done

echo 0 > /proc/driver/thermal/sspm_thermal_throttle 2>/dev/null || true

# --- System Properties ---
settings put system persist.sys.power_mode_perf 1 2>/dev/null || truesetprop persist.sys.power_mode_perf 1 2>/dev/null || true
settings put global sustained_performance_mode_enabled 1 2>/dev/null || true
setprop vendor.perf.framepacing.enable 1 2>/dev/null || true
setprop persist.sys.sf.frame_rate_multiple_threshold 1 2>/dev/null || true

# --- Detect DVFSRC path ---
dvfsrc_a=/sys/devices/platform/soc/1c00f000.dvfsrc
dvfsrc_b=/sys/devices/platform/1c00f000.dvfsrc
dvfsrc_c=/sys/devices/platform/1c013000.dvfsrc
dvfsrc_d=/sys/class/devfreq/mtk-dvfsrc-devfreq
dvfsrc_dir=""
for d in "$dvfsrc_a" "$dvfsrc_b" "$dvfsrc_c" "$dvfsrc_d"; do
  if [ -d "$d" ]; then
    dvfsrc_dir="$d"
    break
  fi
done

if [ -z "$dvfsrc_dir" ]; then
  echo "[!] DVFSRC not found. Skipping DDR tuning."
fi

# --- Paths ---
perfmgr=/sys/module/mtk_fpsgo/parameters/perfmgr_enable
pandora_feas=/sys/module/perfmgr_mtk/parameters/perfmgr_enable
fpsgo=/sys/kernel/fpsgo/common/fpsgo_enable
fbt_ceiling=/sys/kernel/fpsgo/fbt/enable_ceiling
ged_kpi=/sys/module/sspm_v3/holders/ged/parameters/is_GED_KPI_enabled
dcs_mode=/sys/kernel/ged/hal/dcs_mode

# Prefer Pandora FEAS if available
if [ -f "$pandora_feas" ]; then
  perfmgr="$pandora_feas"
fi

# --- Helper: lock_value (Fail-safe) ---
lock_value() {
  chmod 664 "$2" 2>/dev/null || true
  echo "$1" > "$2" 2>/dev/null || true
  chmod 444 "$2" 2>/dev/null || true
}

# ==============================
# 🔧 1. Enable Performance Subsystems
# ==============================

[ -f "$fpsgo" ] && lock_value 1 "$fpsgo"
[ -f "$fbt_ceiling" ] && lock_value 1 "$fbt_ceiling"

if [ -f "$perfmgr" ]; then  # Ensure FPSGO is on first
  [ "$(cat "$fpsgo" 2>/dev/null)" != "1" ] && [ -f "$fpsgo" ] && lock_value 1 "$fpsgo"
  
  # GED KPI should be ON unless hybrid governor is used
  if [ ! -d /data/adb/modules/dimensity_hybrid_governor ] && [ -f "$ged_kpi" ]; then
    lock_value 1 "$ged_kpi"
  fi
  lock_value 1 "$perfmgr"
fi

# ==============================
# 🎮 2. GPU: Lock to MAX Frequency
# ==============================

if [ -f /proc/gpufreqv2/stack_signed_opp_table ]; then
  MAX_FREQ=$(head -n1 /proc/gpufreqv2/stack_signed_opp_table 2>/dev/null | awk '{print $3}' | cut -d',' -f1) || true
  if [ -n "$MAX_FREQ" ] && [ "$MAX_FREQ" != "0" ]; then
    echo "[+] Locking GPU to max: ${MAX_FREQ}KHz"
    lock_value "$MAX_FREQ" /sys/kernel/ged/hal/custom_upbound_gpu_freq
    echo -1 > /proc/gpufreqv2/fix_target_opp_index 2>/dev/null || true
    echo 0 0 > /proc/gpufreqv2/fix_custom_freq_volt 2>/dev/null || true
    [ -f /sys/kernel/thermal/gpt ] && echo disable > /sys/kernel/thermal/gpt 2>/dev/null || true
  fi
fi

# ==============================
# 💾 3. DDR: Set Min Freq = Max Freq
# ==============================

if [ -n "$dvfsrc_dir" ]; then
  dvfsrc="$dvfsrc_dir/mtk-dvfsrc-devfreq/devfreq/mtk-dvfsrc-devfreq"
  if [ -f "$dvfsrc/max_freq" ] && [ -f "$dvfsrc/min_freq" ]; then
    MAX_DDR=$(cat "$dvfsrc/max_freq" 2>/dev/null) || true
    if [ -n "$MAX_DDR" ]; then
      echo "[+] Setting DDR min freq to max: $MAX_DDR Hz"
      lock_value "$MAX_DDR" "$dvfsrc/min_freq"
    fi
  fi
fi

# ==============================
# 🚫 4. Disable Power-Saving Features
# ==============================

[ -f "$dcs_mode" ] && lock_value 0 "$dcs_mode"

if [ -f "$ged_kpi" ] && [ ! -d /data/adb/modules/dimensity_hybrid_governor ]; then
  echo "[+] Ensuring GED KPI is ENABLED (required for PerfMgr)..."
  lock_value 1 "$ged_kpi"
fi
# ==============================
# 🚀 PPM Policy Configuration
# ==============================

LOG_FILE="/sdcard/MTK_AI_Engine/MTK_AI_Engine.log"
PPM_PATH="/proc/ppm/policy_status"

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

log_action() {
  echo "[$(date +"%Y-%m-%d %H:%M:%S")] $1" >> "$LOG_FILE" 2>/dev/null || true
}

log_action "Starting PPM Policy Application..."

if [ "$(id -u)" -ne 0 ] 2>/dev/null; then
   echo "[!] Root access required (or not fully active)."
   log_action "WARNING: UID is not 0"
fi

echo "--- Checking PPM Path ---"
if [ ! -f "$PPM_PATH" ]; then
    echo "[!] PPM Path not found: $PPM_PATH"
    log_action "WARNING: PPM Path not found."
elif [ ! -w "$PPM_PATH" ]; then
    echo "[!] PPM Path is Read-Only. Kernel may block userspace writes."
    log_action "WARNING: PPM Path is read-only."
else
    echo "[+] PPM Path is writable. Applying policies..."
    for i in 0 1 2 3 4 5 6 7 8; do
        echo "$i 0" > "$PPM_PATH" 2>/dev/null && echo "   [-] Policy $i Disabled" || echo "   [!] Failed Policy $i (skipped)"
    done
    echo "9 1" > "$PPM_PATH" 2>/dev/null && echo "   [+] Policy 9 (SYS_BOOST) Enabled" || echo "   [!] Failed Policy 9 (skipped)"
fi

[ -f "$PPM_PATH" ] && { echo "--- New PPM Status ---"; cat "$PPM_PATH" 2>/dev/null; }

# --- I/O & Thermal Tweaks ---
echo disabled | tee /sys/devices/virtual/thermal/thermal_zone*/mode 2>/dev/null || true

for q in /sys/block/*/queue; do 
  echo 8192 | tee "$q/read_ahead_kb" 2>/dev/null || true
  echo none | tee "$q/scheduler" 2>/dev/null || true
done

for d in /sys/class/devfreq/*/; do
  f=$(awk '{print $NF}' "$d/available_frequencies" 2>/dev/null) || true
  [ -n "$f" ] && echo "$f" | tee "$d/min_freq" 2>/dev/null || true
done

# Stop thermal throttling services safely (Combined Multi-Layer Approach)
ps -A -w 2>/dev/null | grep -i thermal | grep -v grep | awk '{print $NF}' | while read -r svc_path; do
  
  # 1. Extract clean service name (strip directory paths like /vendor/bin/hw/)
  clean_svc="${svc_path##*/}"
  
  # 2. Apply your rule: if name is long (>12 chars) and contains "thermal", append *thermal*
  target_svc="$clean_svc"
  if [[ ${#clean_svc} -gt 12 && "$clean_svc" == *"thermal"* ]]; then
    target_svc="${clean_svc}*thermal*"
  fi
  
  # --- LAYER 1: Graceful Stop ---
  # Tells Android 'init' to stop it, which is the official way to prevent respawn
  setprop ctl.stop "$clean_svc" 2>/dev/null || true
  stop "$target_svc" 2>/dev/null || true
  
  # --- LAYER 2: SIGSTOP (The Freeze) ---
  # Suspends the process entirely (0% CPU). 'init' sees the PID is still alive, 
  # so it usually does not trigger a respawn. (Uses clean_svc to ensure it finds the real process)
  pkill -STOP -f "$clean_svc" 2>/dev/null || true
  
  # --- LAYER 3: cpulimit (The Neuter) ---
  # If the process somehow wakes up or wasn't fully stopped, this restricts it to 1% CPU.
  # (Silently fails if cpulimit isn't installed, which is safe)
  pid=$(pgrep -f "$clean_svc" | head -n 1)
  if [ -n "$pid" ]; then
    nohup /data/adb/modules/MTK_AI/lib/cpulimit -p "$pid" -l 1 -z 2>/dev/null &
  fi
  
done

# ==============================
# ✅ Done
# ==============================

echo ""
echo "✅ MAXIMUM PERFORMANCE ACTIVE!"
echo "   - PerfMgr / FPSGO / FBT: enabled"
echo "   - GPU: locked to max frequency"
echo "   - DDR: min freq = max"
echo "   - DCS: disabled"
echo "   - All failures safely skipped"
echo ""
echo "⚠️  Monitor temperature! Reboot to restore defaults."
