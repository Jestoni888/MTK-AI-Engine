#!/system/bin/sh
#!/data/adb/modules/MTK_AI/busybox sh

LOG_FILE="/sdcard/MTK_AI_Engine/MTK_AI_Engine.log"
CPULIMIT="/data/adb/modules/MTK_AI/lib/cpulimit"

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE" || true
}

BB="/data/adb/modules/MTK_AI/busybox"
SAVE_DIR="/sdcard/MTK_AI_Engine/cooldown_values"

log_msg "→ Applying Normal EEM offsets from sdcard..."
for i in b:/proc/eem/EEM_DET_B/eem_offset l:/proc/eem/EEM_DET_L/eem_offset cci:/proc/eem/EEM_DET_CCI/eem_offset bl:/proc/eem/EEM_DET_BL/eem_offset gpu:/proc/eemg/EEMG_DET_GPU/eemg_offset gpu_hi:/proc/eemg/EEMG_DET_GPU_HI/eemg_offset; do
  k=${i%%:*}; p=${i#*:}; v=$(cat /sdcard/MTK_AI_Engine/eem_offsets/normal/$k.txt 2>/dev/null)
  [ -n "$v" ] && echo "$v" > "$p" 2>/dev/null && log_msg "[✓] $k: ${v}mV"
done || true

su -c "cmd wifi force-hi-perf-mode disabled" || true
su -c "cmd wifi force-low-latency-mode disabled" || true
su -c "iw dev wlan0 set power_save on" || true
su -c "iw phy phy0 set retry short 2 long 2" || true
su -c "ifconfig wlan0 txqueuelen 10" || true
su -c "cmd wifi set-poll-rssi-interval-msecs 10000" || true
su -c "cmd wifi set-wifi-sleep-policy screen-off" || true
su -c "settings put global wifi_sleep_policy 2" || true
su -c "cmd wifi set-roaming-scan-interval 120" || true
su -c "settings put global wifi_watchdog_poor_network_test_enabled 0" || true
su -c "settings put global wifi_watchdog_ap_count 5" || true
su -c "settings put global wifi_watchdog_max_ap_checks 2" || true
su -c "settings put global wifi_framework_enabled 1" || true
su -c "cmd wifi reassociate" || true
su -c "echo Y > /sys/module/wlan/parameters/ps" || true
su -c "echo 1 > /sys/module/wlan/parameters/wlm" || true

pkill -f cpulimit || true

if [ -f "/sdcard/MTK_AI_Engine/limit_surfaceflinger" ]; then
        SF_PID=$(pidof surfaceflinger)
        echo $SF_PID
        nohup $CPULIMIT -p $SF_PID -l 80 -z 2>/dev/null &
fi

setprop 'persist.sys.power_mode_perf' '0' || true
settings put system persist.sys.power_mode_perf 0 2>/dev/null || true

settings put system 'accelerometer_rotation' '0' || true
su -c "cmd power set-fixed-performance-mode-enabled false" || true
su -c "settings put global power_manager_constants fixed_performance_mode=false" || true

settings put global 'activity_manager_constants' 'max_cached_processes=32,background_settle_time=60000,fgs_start_deny_exposure_time=10000,fgservice_min_show_time=5000,fgservice_bg_start_timeout=30000,max_phantom_processes=32,process_limit=-1,enable_fg_boost=false' || true

echo "0" > /sys/kernel/fpsgo/common/fpsgo_enable || true
echo "0" > /sys/kernel/fpsgo/fstb/fstb_self_ctrl_fps_enable || true
echo "0" > /sys/kernel/fpsgo/fbt/enable_switch_down_throttle || true
echo "0" > /sys/kernel/fpsgo/fstb/tfps_to_powerhal_enable || true
echo "0" > /sys/kernel/fpsgo/fstb/set_cam_active || true

echo "1" > /proc/cpufreq/cpufreq_power_mode || true
echo "0" > /proc/cpufreq/cpufreq_cci_mode || true

setprop 'dalvik.vm.usap_pool_enabled' 'true' || true

device_config put activity_manager max_phantom_processes 16 || true
device_config put activity_manager max_cached_processes 32 || true
device_config put activity_manager use_compaction true || true
am set-process-limit -1 || true

cmd activity trim-memory moderate || true
sysctl -w vm.swappiness=100 || true
sysctl -w vm.vfs_cache_pressure=100 || true
sysctl -w vm.dirty_ratio=20 || true
sysctl -w vm.dirty_background_ratio=10 || true

settings put global app_standby_enabled 1 || true
settings put global background_dex_opt_job true || true
setprop persist.sys.game_mode 0 || true
# --- Generic Android / AOSP ---
start thermal || true
start thermald || true
start thermalloadalgod || true
start thermalservice || true
start android.hardware.thermal@1.0-service || true
start android.hardware.thermal@2.0-service || true
start android.hardware.thermal@3.0-service || true
start android.hardware.thermal-service || true
start android.thermal-hal || true

# --- Qualcomm (QTI) ---
start vendor.qti.thermal-engine || true
start vendor.thermal-engine || true
start thermal-engine || true
start vendor.thermal_manager || true
start vendor.thermal-manager || true
start vendor.thermal-hal || true
start vendor.thermal-hal-1-0 || true
start vendor.thermal-hal-2-0 || true
start vendor.thermal-hal-3-0 || true
start vendor.qti.hardware.thermal@1.0-service || true
start vendor.qti.hardware.thermal@2.0-service || true
start vendor.qti.hardware.thermal@3.0-service || true
start vendor-thermal-1-0 || true

# --- MediaTek (MTK) ---
start vendor.thermal-hal-2.0.mtk || true
start vendor.mediatek.hardware.thermal@1.0-service || true
start vendor.mediatek.hardware.thermal@2.0-service || true
start mtk_thermal_manager || true
start mtk_thermal_hal || true
start thermal_mtk || true
start thermal_core || true
start thermal_manager || true

# --- Samsung (Exynos & QTI variants) ---
start sec-thermal-1-0 || true
start debug_pid.sec-thermal-1-0 || true
start exynos-thermal || true
start samsung-thermal || true
start vendor.samsung.hardware.thermal@1.0-service || true
start vendor.samsung.hardware.thermal@2.0-service || true
start thermald-samsung || true

# --- Xiaomi / Redmi / POCO (MIUI/HyperOS) ---
start mi_thermald || true
start xiaomi_thermal || true
start vendor.xiaomi.hardware.thermal@1.0-service || true
start vendor.xiaomi.hardware.thermal@2.0-service || true
# --- Oppo / Realme / OnePlus (BBK family) ---
start oppo_thermal || true
start realme_thermal || true
start oneplus_thermal || true
start vendor.oppo.hardware.thermal@1.0-service || true
start vendor.realme.hardware.thermal@1.0-service || true

# --- Huawei / Honor ---
start huawei_thermal || true
start hi_thermal || true
start vendor.huawei.hardware.thermal@1.0-service || true

# --- Sony, LG, Motorola ---
start sony_thermal || true
start lg_thermal_daemon || true
start motorola_thermal || true

# --- Google Pixel ---
start pixel-thermal || true
start google-thermal-hal || true
start vendor.google.hardware.thermal@1.0-service || true

# --- Legacy / Miscellaneous / Symlinks ---
start vendor.thermal-symlinks || true
start vendor.thermal.symlinks || true
start thermal_mnt_hal_service || true
start thermal-hal || true
start thermal_server || true
start thermal_daemon || true
start thermal_monitor || true
start thermal_control || true
start thermal_repeater || true
start thermal_notify || true

for zone in /sys/devices/virtual/thermal/thermal_zone*/mode; do
    chmod 777 "$zone" || true
    echo enabled | tee "$zone" || true
done || true

# Loop through all saved config files
for conf in $SAVE_DIR/*.conf; do
    [ -f "$conf" ] || continue
    
    # Read line (format: PATH=VALUE)
    line=$($BB cat "$conf") || true
    
    # Extract Path and Value
    fpath=$(echo "$line" | $BB cut -d'=' -f1) || true
    fval=$(echo "$line" | $BB cut -d'=' -f2-) || true    
    # Apply if path exists
    if [ -f "$fpath" ]; then
        echo "$fval" > "$fpath" 2>/dev/null && log_msg "Restored: $fpath" || true
    fi
done || true

log_msg "MTK AI Values Restored." || true
echo "0" > /proc/sys/kernel/panic || true
    
# 1. Apply Properties (Fast)
setprop debug.hwui.render_ahead 0 || true
setprop persist.sys.miravision.vivid.mode 0 || true
setprop persist.sys.force_vivid 0 || true
setprop persist.sys.framepredict.enable false || true
setprop debug.sf.latch_unsignaled false || true
setprop debug.cpurendering false || true
setprop debug.egl.force_msaa false || true
setprop persist.sys.ui.hw true || true
setprop persist.sys.use_dithering 0 || true
setprop debug.sf.early_phase_offset_ns 0 || true
setprop debug.sf.early_gl_phase_offset_ns 0 || true
setprop debug.sf.high_fps_early_phase_offset_ns 0 || true
setprop debug.sf.high_fps_early_gl_phase_offset_ns 0 || true
setprop debug.hwui.disable_vsync false || true
setprop debug.sf.enable_hwc_vds 0 || true

# Powersaving in normal use
setprop persist.sys.batterysaver true || true
setprop persist.sys.doze_mode true || true

# OpenGL Default (Skia OpenGL ES)
setprop debug.hwui.renderer skiagl || true
setprop debug.renderengine.backend skiaglthreaded || true
setprop debug.hwui.shadow.renderer skiagl || true
setprop ro.ui.pipeline opengl || true
setprop debug.hwui.use_vulkan false || true
setprop debug.hwui.force_vulkan false || true
setprop ro.hwui.use_vulkan false || true
setprop ro.hwui.hardware.vulkan false || true
setprop debug.composition.type gpu || true

# Limit background process
setprop persist.sys.max_background 10 || true
setprop persist.sys.wifi.suspend_opt 1 || true # Enable Wi-Fi suspend optimization

service call SurfaceFlinger 1008 i32 0 >/dev/null 2>&1 || true
        
log_msg "🟢 NORMAL MODE PROPS applied" || true

[ "$(id -u)" != "0" ] && { echo "Root required"; exit 1; } || true

# Enable all PPM policies dynamically
if [ -f /proc/ppm/policy_status ]; then
  # Extract existing policy indices and set them to 1 (enabled)
  grep -oE '\[[0-9]+\]' /proc/ppm/policy_status | grep -oE '[0-9]+' | while read -r idx; do
    echo "$idx 1" > /proc/ppm/policy_status 2>/dev/null || true
  done
fi

echo "Done" || true

log -t "NetTweak" "Starting network tweaks..." || true

# === Universal Kernel Tweaks ===
if [ -f /proc/sys/net/ipv4/tcp_congestion_control ]; then
  echo bbr > /proc/sys/net/ipv4/tcp_congestion_control 2>/dev/null || \
  echo cubic > /proc/sys/net/ipv4/tcp_congestion_control 2>/dev/null || true
  log -t "NetTweak" "TCP congestion control set" || true
fi

if [ -f /proc/sys/net/ipv4/tcp_window_scaling ]; then
  echo 1 > /proc/sys/net/ipv4/tcp_window_scaling || true
fi

if [ -f /proc/sys/net/ipv4/tcp_low_latency ]; then
  echo 1 > /proc/sys/net/ipv4/tcp_low_latency || true
fi

# === Platform Detection & Runtime Props ===
PLATFORM=$(getprop ro.board.platform) || true
BASEBAND=$(getprop ro.baseband) || true

# --- MediaTek ---
if echo "$PLATFORM" | grep -qiE "mt[0-9]+|mt6[0-9]+"; then
  log -t "NetTweak" "Detected MediaTek. Applying MTK runtime tweaks." || true
  setprop persist.radio.mtksms 1 || true
  setprop persist.meta.dumpdata 0 || true
  setprop persist.radio.custom.ecc 1 || true

# --- Qualcomm ---
elif echo "$PLATFORM" | grep -qiE "msm[0-9]+|sdm[0-9]+|sm[0-9]+|kona|lito|lahaina"; then
  log -t "NetTweak" "Detected Qualcomm. Applying QMI runtime tweaks." || true
  setprop persist.data.netmgrd.qos.enable true || true
  setprop persist.data.mode concurrent || true
  setprop persist.rmnet.data.enable true || true
  setprop persist.data.iwlan.enable true || true

# --- Samsung/Exynos ---
elif echo "$BASEBAND" | grep -qiE "exynos"; then
  log -t "NetTweak" "Detected Exynos. Applying Samsung runtime tweaks." || true
  setprop persist.data.mode concurrent || true
# --- Universal Fallback ---
else
  log -t "NetTweak" "Unknown Platform. Applying universal runtime tweaks." || true
fi

# === Interface Route Tweaks ===
sleep 5 || true
for iface in rmnet0 rmnet_data0 pdp0 ccmni0; do
  if ip link show $iface >/dev/null 2>&1; then
    log -t "NetTweak" "Applying route tweaks to $iface" || true
    ip route change default dev $iface initcwnd 30 initrwnd 30 2>/dev/null || true
    break
  fi
done || true

# === Flush DNS Cache ===
ndc resolver flushdefaultif 2>/dev/null || true
ndc resolver flushif 2>/dev/null || true

sh "/data/adb/modules/MTK_AI/script_runner/mtk_ai_manual" || true
sh "/data/adb/modules/MTK_AI/MTK_AI/AI_MODE/normal_mode/bypass_off" || true

log -t "NetTweak" "Network Tweaks Applied Successfully." || true
